# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/invoicehub
# OR MongoDB Atlas:
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/invoicehub

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Email (Gmail)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=InvoiceHub <your_gmail@gmail.com>

# Company Info (shown on invoices)
COMPANY_NAME=Your Company Name
COMPANY_ADDRESS=123 Business Park, Mumbai 400001
COMPANY_GST=27AABCU9603R1ZX
COMPANY_PHONE=+91 98765 43210
COMPANY_EMAIL=your_gmail@gmail.com
COMPANY_WEBSITE=https://yourcompany.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
